{
	"schemaVersion": 1,
	"id": "unboundle",
	"version": "${version}",
	"name": "Unboundle",
		"description": "Use items directly out of the bundle, and manage them easily with a dynamic tooltip.",
	"authors": [
		"Skyros4"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/unboundle",
		"issues": "https://github.com/Skyros4/Unboundle/issues",
		"sources": "https://github.com/Skyros4/Unboundle"
	},
	"license": "LGPL-3.0-only",
	"icon": "assets/unboundle/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"unboundle.Unboundle"
		],
		"modmenu": [
			"unboundle.ModMenuEntrypoint"
		],
		"client": [
			"unboundle.UnboundleClient"
		]
	},
	"mixins": [
		"unboundle.mixins.json",
		{
			"config": "unboundle.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.14.0",
		"minecraft": "~1.21.10",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*",
		"cloth-config": "*"
	}
}